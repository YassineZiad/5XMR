<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="gestion_contacts.MainPage">

    <StackLayout Margin="20">
        <Button Text="Nouveau contact" Clicked="OnNewContactClicked" VerticalOptions="CenterAndExpand" />

        <CollectionView x:Name="ContactsList" Margin="20" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame HasShadow="True" BorderColor="#EEEEEE" CornerRadius="5" Padding="10">
                        <StackLayout>
                            <StackLayout Orientation="Horizontal">
                                <Label Text="{Binding FirstName}" FontSize="Medium" Margin="5,0,0,0" />
                                <Label Text="{Binding LastName}" FontSize="Medium" />
                            </StackLayout>

                            <Label Text="{Binding GSMNumber}" FontSize="Small" TextColor="DeepSkyBlue" Margin="0,2,0,0" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>

</ContentPage>
